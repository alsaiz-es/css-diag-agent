#!/bin/bash
### BEGIN INIT INFO
# Provides:          css-echo-server
# Required-Start:    $network $remote_fs
# Required-Stop:     $network $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Description:       Synthetic TCP Echo Server
### END INIT INFO

NAME="css-echo-server"
CONF="/opt/css_diag_agent/diagnet.conf"
PIDFILE="/var/run/${NAME}.pid"
LOGFILE="/var/log/css_diag_agent/echo_server.log"

[ -f "$CONF" ] && . "$CONF"
DAEMON="$(command -v python3 2>/dev/null || command -v python2.6 2>/dev/null || command -v python 2>/dev/null || echo python)"
DAEMON_ARGS="/opt/css_diag_agent/diagnet/echo_server.py --bind 0.0.0.0 --port ${PEER_PORT:-9400}"

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME ya está en ejecución."
        return 0
    fi
    echo "Iniciando $NAME..."
    nohup $DAEMON $DAEMON_ARGS >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
}

stop() {
    if [ ! -f "$PIDFILE" ] || ! kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME no está en ejecución."
        return 0
    fi
    echo "Parando $NAME..."
    kill "$(cat "$PIDFILE")"
    rm -f "$PIDFILE"
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME en ejecución (PID $(cat "$PIDFILE"))"
    else
        echo "$NAME parado"
        return 1
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)  status ;;
    *)       echo "Uso: $0 {start|stop|restart|status}"; exit 1 ;;
esac
